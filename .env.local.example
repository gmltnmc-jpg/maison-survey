# Supabase — created after the new project is provisioned (step B).
# NEXT_PUBLIC_* are exposed to the browser; the others are server-only secrets.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose to the client. Used by /api/submit (service_role).
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. 32-byte key, base64-encoded, for AES-256-GCM RRN encryption.
# Generate once and store ONLY here and in Vercel env vars:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
RRN_ENC_KEY=
