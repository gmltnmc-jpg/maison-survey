# Public Supabase project URL. Safe to expose in browser code.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anon key. Safe to expose in browser code, but RLS must protect data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role key. NEVER expose this to the browser.
# Used only by trusted server code such as /api/submit.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only AES-256-GCM key for resident registration number encryption.
# NEVER expose this to the browser. Do not commit a real value.
RRN_ENC_KEY=
